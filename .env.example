# =====================================================
# Admin (必須)
# =====================================================
# /admin と /api/analyze を Basic 認証で保護するパスワード。
# 未設定だと /admin と /api/analyze は 503 を返す (フェイルクローズ)。
# ユーザ名は何でも良い (パスワードのみ照合)。
ADMIN_PASSWORD=change-me

# =====================================================
# OpenAI (必須)
# =====================================================
# https://platform.openai.com/api-keys から発行
OPENAI_API_KEY=sk-...

# モデル指定 (任意)
# OPENAI_VISION_MODEL=gpt-4o-mini
# OPENAI_RESEARCH_MODEL=gpt-4o
# OPENAI_SEARCH_CONTEXT_SIZE=low  # low|medium|high
# OPENAI_MAX_BANDS=8

# =====================================================
# Spotify (任意・アー写と代表曲の精度向上に使用)
# =====================================================
# https://developer.spotify.com/dashboard で発行 (Client Credentials flow)
# 設定すると:
#   - アー写を Spotify アーティスト画像から取得 (CDN ホスト, 高品質)
#   - 代表曲ごとに Spotify リンクを自動付与
#   - 関連リンクの Spotify URL を verified なものに差し替え
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# =====================================================
# Turso (libSQL) — DB
# =====================================================
# ローカル開発:
#   - SQLite ファイル直挿し: file:./local.db
#   - turso dev サーバ: http://127.0.0.1:8080
# 本番:
#   - Turso 管理画面で発行された libsql:// URL
TURSO_DATABASE_URL=file:./local.db
# 本番 (libsql://) でのみ必要。file: / turso dev では空でOK
TURSO_AUTH_TOKEN=
